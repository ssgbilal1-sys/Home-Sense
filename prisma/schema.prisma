generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       String
  image       String
  images      String   @default("[]")
  video       String?
  category    String   @default("Vanities")
  featured    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id          String   @id @default("main")
  phone       String   @default("+92 300 1234567")
  whatsapp    String   @default("+92 300 1234567")
  email       String   @default("info@zilver.co")
  instagram   String   @default("@zilver.co")
  facebook    String   @default("")
  youtube     String   @default("")
  address     String   @default("")
  updatedAt   DateTime @updatedAt
}
